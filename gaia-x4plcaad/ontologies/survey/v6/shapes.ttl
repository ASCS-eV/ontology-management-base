@prefix envited-x: <https://w3id.org/ascs-ev/envited-x/envited-x/v3/> .
@prefix manifest: <https://w3id.org/ascs-ev/envited-x/manifest/v5/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix survey: <https://w3id.org/gaia-x4plcaad/ontologies/survey/v6/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

survey:SurveyResultDataOfferingShape a sh:NodeShape ;
    sh:closed false ;
    sh:property [ sh:maxCount 1 ;
            sh:message "Each SurveyResultDataOffering must have exactly one associated ResourceDescription (either inline or a valid manifest:Link)."@en ;
            sh:minCount 1 ;
            sh:or ( [ sh:node envited-x:ResourceDescriptionShape ] [ sh:and ( manifest:LinkShape envited-x:ExtendedLinkShape ) ] ) ;
            sh:path survey:hasResourceDescription ],
        [ sh:maxCount 1 ;
            sh:message "Each SurveyResultDataOffering must have one associated DomainSpecification with content."@en ;
            sh:minCount 1 ;
            sh:node survey:ResultDomainSpecificationShape ;
            sh:path survey:hasDomainSpecification ],
        [ sh:maxCount 1 ;
            sh:message "Each SurveyResultDataOffering must have exactly one manifest."@en ;
            sh:minCount 1 ;
            sh:or ( [ sh:and ( manifest:ManifestShape envited-x:ManifestShape ) ] [ sh:node envited-x:ManifestLinkReferenceShape ] ) ;
            sh:path survey:hasManifest ] ;
    sh:targetClass survey:SurveyResultDataOffering .

survey:SurveyServiceOfferingShape a sh:NodeShape ;
    sh:closed false ;
    sh:property [ sh:maxCount 1 ;
            sh:message "Each SurveyServiceOffering must have exactly one associated ServiceOfferingBase (either inline or a valid manifest:Link)."@en ;
            sh:minCount 1 ;
            sh:or ( [ sh:node envited-x:ServiceOfferingBaseShape ] [ sh:and ( manifest:LinkShape envited-x:ExtendedLinkShape ) ] ) ;
            sh:path survey:hasServiceOffering ],
        [ sh:maxCount 1 ;
            sh:message "Each SurveyServiceOffering must have one associated DomainSpecification with content."@en ;
            sh:minCount 1 ;
            sh:node survey:ServiceDomainSpecificationShape ;
            sh:path survey:hasDomainSpecification ],
        [ sh:maxCount 1 ;
            sh:message "Each SurveyServiceOffering must have exactly one manifest."@en ;
            sh:minCount 1 ;
            sh:or ( [ sh:and ( manifest:ManifestShape envited-x:ManifestShape ) ] [ sh:node envited-x:ManifestLinkReferenceShape ] ) ;
            sh:path survey:hasManifest ] ;
    sh:targetClass survey:SurveyServiceOffering .

<https://w3id.org/gaia-x4plcaad/ontologies/survey/v6/shapes/result-data-offering> a owl:Ontology ;
    owl:imports <https://w3id.org/gaia-x4plcaad/ontologies/survey/v6> .

<https://w3id.org/gaia-x4plcaad/ontologies/survey/v6/shapes/service-offering> a owl:Ontology ;
    owl:imports <https://w3id.org/gaia-x4plcaad/ontologies/survey/v6> .

survey:ResultContentShape a sh:NodeShape ;
    sh:closed false ;
    sh:property [ skos:example "'Date 1'" ;
            sh:datatype xsd:dateTime ;
            sh:description "When the survey was started." ;
            sh:maxCount 1 ;
            sh:message "Validation of survey start time failed." ;
            sh:minCount 1 ;
            sh:name "Survey start time" ;
            sh:path survey:surveyStartTime ],
        [ skos:example "'Date 1'" ;
            sh:datatype xsd:dateTime ;
            sh:description "When the survey was closed." ;
            sh:maxCount 1 ;
            sh:message "Validation of survey close time failed." ;
            sh:minCount 1 ;
            sh:name "Survey close time" ;
            sh:path survey:surveyCloseTime ],
        [ sh:class survey:SurveyServiceOffering ;
            sh:description "Accompanied survey service offering." ;
            sh:maxCount 1 ;
            sh:message "Validation of assigned survey service offering failed." ;
            sh:minCount 1 ;
            sh:name "Survey service offering" ;
            sh:nodeKind sh:IRI ;
            sh:path survey:belongsTo ],
        [ sh:datatype xsd:float ;
            sh:maxCount 1 ;
            sh:message "Validation of data size failed." ;
            sh:minCount 0 ;
            sh:name "Data size" ;
            sh:path survey:dataSize ] .

survey:ResultDomainSpecificationShape a sh:NodeShape ;
    sh:closed false ;
    sh:property [ sh:maxCount 1 ;
            sh:message "Each ResultDomainSpecification must have one Content facet."@en ;
            sh:minCount 1 ;
            sh:node survey:ResultContentShape ;
            sh:path survey:hasContent ] .

survey:ServiceContentShape a sh:NodeShape ;
    sh:closed false ;
    sh:property [ skos:example "'Example URL'" ;
            sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "Validation of survey URL failed." ;
            sh:minCount 1 ;
            sh:name "Survey URL" ;
            sh:path survey:surveyUrl ],
        [ skos:example "'Date 1'" ;
            sh:datatype xsd:dateTime ;
            sh:description "When the survey was created" ;
            sh:maxCount 1 ;
            sh:message "Validation of survey creation time failed." ;
            sh:minCount 1 ;
            sh:name "Survey creation time" ;
            sh:path survey:surveyCreationTime ],
        [ skos:example "'Date 3'" ;
            sh:datatype xsd:dateTime ;
            sh:description "When the survey will end automatically" ;
            sh:maxCount 1 ;
            sh:message "Validation of survey end time failed." ;
            sh:minCount 1 ;
            sh:name "Survey end time" ;
            sh:path survey:surveyEndTime ],
        [ sh:datatype xsd:float ;
            sh:maxCount 1 ;
            sh:message "Validation of data size failed." ;
            sh:minCount 0 ;
            sh:name "Data size" ;
            sh:path survey:dataSize ] .

survey:ServiceDomainSpecificationShape a sh:NodeShape ;
    sh:closed false ;
    sh:property [ sh:maxCount 1 ;
            sh:message "Each ServiceDomainSpecification must have one Content facet."@en ;
            sh:minCount 1 ;
            sh:node survey:ServiceContentShape ;
            sh:path survey:hasContent ] .

