	rdfs:subClassOf gx:MemoryClasses ;
	skos:definition "This type of DRAM memory can find and even fix corrupted data." .
gx:MemoryClasses\/GDDR5 a owl:Class ;
	rdfs:label "GDDR5" ;
	rdfs:subClassOf gx:MemoryClasses ;
