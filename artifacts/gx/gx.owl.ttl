gx:MemoryClasses\/DDR\%20SDRAM a owl:Class ;
	rdfs:label "DDR SDRAM" ;
	rdfs:subClassOf gx:MemoryClasses ;
	skos:definition "SDRAM evolution with twice the data transmission frequency." .
gx:MemoryClasses\/DDR4 a owl:Class ;
	rdfs:label "DDR4" ;
	rdfs:subClassOf gx:MemoryClasses ;
	skos:definition "Fourth generation of the synchronous dynamic random-access memory interface, improves speed and efficiency in data transfer actions." .
gx:MemoryClasses\/DDR5 a owl:Class ;
	rdfs:label "DDR5" ;
	rdfs:subClassOf gx:MemoryClasses ;
	skos:definition "Fifth generation of the synchronous dynamic random-access memory interface, planned to reduce power consumption." .
gx:MemoryClasses\/ECC\%20DRAM a owl:Class ;
	rdfs:label "ECC DRAM" ;
	rdfs:subClassOf gx:MemoryClasses ;
	skos:definition "This type of DRAM memory can find and even fix corrupted data." .
gx:MemoryClasses\/GDDR5 a owl:Class ;
	rdfs:label "GDDR5" ;
	rdfs:subClassOf gx:MemoryClasses ;
	skos:definition "Type of memory that is also based on the DDR standard, but designed specifically to be used in graphic cards." .
gx:MemoryClasses\/GDDR6 a owl:Class ;
	rdfs:label "GDDR6" ;
	rdfs:subClassOf gx:MemoryClasses ;
	skos:definition "Evolution of GDDR5 memory, designed for high-performance computing." .
gx:MemoryClasses\/SDRAM a owl:Class ;
	rdfs:label "SDRAM" ;
	rdfs:subClassOf gx:MemoryClasses ;
	skos:definition "Synchronous DRAM, improves performance in data transfer actions through its pins." .
gx:MemoryClasses\/other a owl:Class ;
