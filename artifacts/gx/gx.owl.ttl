	rdfs:subClassOf _:b062210b7af37 , _:b19c5d6ef0935 , _:b5b979d9a775b , _:bdabd0d1dc47e , _:bde2e4caf2f0f , _:bec42affbe1ca ;
	skos:definition "Detail on how to calculate or verify a checksum." ;
