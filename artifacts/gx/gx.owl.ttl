dcterms:conformsTo a owl:DatatypeProperty ;
	rdfs:label "conformsTo" ;
	rdfs:range xsd:string ;
	skos:definition "An established standard to which the described resource conforms." ;
	skos:inScheme gx:slots .
dcterms:format a owl:DatatypeProperty ;
	rdfs:label "format" ;
	rdfs:range xsd:string ;
	skos:definition "Format of the dataset distribution (PDF, CSV, …)" ;
	skos:inScheme gx:slots .
dcterms:identifier a owl:DatatypeProperty ;
	rdfs:label "identifier" ;
	rdfs:range xsd:string ;
	skos:definition "Unique UUID4" ;
	skos:inScheme gx:slots .
dcterms:issued a owl:DatatypeProperty ;
	rdfs:label "issued" ;
	rdfs:range xsd:date ;
	skos:definition "Publication date in ISO 8601 format" ;
	skos:inScheme gx:slots .
dcterms:language a owl:DatatypeProperty ;
	rdfs:label "language" ;
	rdfs:range xsd:string ;
	skos:definition "Language" ;
	skos:inScheme gx:slots .
dcterms:license a owl:DatatypeProperty ;
	rdfs:label "licenses" ;
	rdfs:range xsd:string ;
	skos:definition "A list of URIs to license documents." ;
	skos:inScheme gx:slots .
dcterms:title a owl:DatatypeProperty ;
	rdfs:label "title" ;
	rdfs:range xsd:string ;
	skos:definition "Title of a concept." ;
	skos:inScheme gx:slots .
<http://qudt.org/schema/qudt/QuantityKind> a owl:Class ;
	rdfs:label "QuantityKind" ;
	rdfs:subClassOf _:c14n3001 , _:c14n3756 , _:c14n6347 , _:c14n784 , _:c14n8014 , _:c14n8374 , _:c14n8990 ;
	owl:equivalentClass gx:QuantityKind ;
	skos:definition "A Quantity Kind is any observable property that can be measured and quantified numerically. Familiar examples include physical properties such as length, mass, time, force, energy, power, electric charge, etc. Less familiar examples include currency, interest rate, price to earning ratio, and information capacity." ;
	skos:inScheme gx:quantity .
<http://qudt.org/schema/qudt/applicableUnit> a owl:DatatypeProperty ;
	rdfs:label "applicableUnit" ;
	skos:definition "Unit of physical quantity of the class https://qudt.org/schema/qudt/QuantityKind" ;
	skos:inScheme gx:slots .
<http://qudt.org/schema/qudt/floatPercentage> a rdfs:Datatype .
<http://qudt.org/schema/qudt/quantityValue> a owl:DatatypeProperty ;
	rdfs:label "quantityValue" ;
	rdfs:range xsd:float ;
	skos:definition "is the measurement of an observable property of a particular object, event, or physical system." ;
	skos:inScheme gx:slots .
<http://qudt.org/vocab/quantitykind/DataRate> a owl:Class ;
	rdfs:label "DataRate" ;
	rdfs:subClassOf <http://qudt.org/schema/qudt/QuantityKind> ;
	owl:equivalentClass gx:DataRate ;
	skos:inScheme gx:quantity .
<http://qudt.org/vocab/quantitykind/Frequency> a owl:Class ;
	rdfs:label "Frequency" ;
	rdfs:subClassOf <http://qudt.org/schema/qudt/QuantityKind> ;
	owl:equivalentClass gx:Frequency ;
	skos:inScheme gx:quantity .
<http://qudt.org/vocab/quantitykind/Power> a owl:Class ;
	rdfs:label "Power" ;
	rdfs:subClassOf <http://qudt.org/schema/qudt/QuantityKind> ;
	owl:equivalentClass gx:Power ;
	skos:inScheme gx:quantity .
<http://qudt.org/vocab/quantitykind/Time> a owl:Class ;
	rdfs:label "Time" ;
	rdfs:subClassOf <http://qudt.org/schema/qudt/QuantityKind> ;
	owl:equivalentClass gx:Time ;
	skos:inScheme gx:quantity .
<http://www.w3.org/2006/vcard/ns#locality> a owl:DatatypeProperty ;
	rdfs:label "locality" ;
	rdfs:range xsd:string ;
	skos:definition "The locality (e.g. city or town) associated with the address." ;
	skos:inScheme gx:slots .
<http://www.w3.org/2006/vcard/ns#postal-code> a owl:DatatypeProperty ;
	rdfs:label "postalCode" ;
	rdfs:range xsd:string ;
	skos:definition "The local postal code of the address." ;
	skos:inScheme gx:slots .
<http://www.w3.org/2006/vcard/ns#region> a owl:ObjectProperty ;
	rdfs:label "region" ;
	rdfs:range gx:NUTS2Region ;
	skos:definition "The NUTS2 region code of the geographical location." ;
	skos:inScheme gx:slots .
<http://www.w3.org/2006/vcard/ns#street-address> a owl:DatatypeProperty ;
	rdfs:label "streetAddress" ;
	rdfs:range xsd:string ;
	skos:definition "The street address of a postal address." ;
	skos:inScheme gx:slots .
dcat:Dataset a owl:DatatypeProperty ;
	rdfs:label "dataSets" ;
	rdfs:range xsd:string ;
	skos:definition "description of the data sets provided by the Data Product - using DCAT-3 formalism" ;
	skos:inScheme gx:data-product .
dcat:byteSize a owl:DatatypeProperty ;
	rdfs:label "byteSize" ;
	rdfs:range xsd:string ;
	skos:definition "Size of the dataset distribution" ;
	skos:inScheme gx:slots .
dcat:compressFormat a owl:DatatypeProperty ;
	rdfs:label "compressFormat" ;
	rdfs:range xsd:string ;
	skos:definition "The compression format of the distribution in which the data is contained in a compressed form" ;
	skos:inScheme gx:slots .
dcat:contactPoint a owl:DatatypeProperty ;
	rdfs:label "contactPoint" ;
	rdfs:range xsd:string ;
	skos:definition "Contact to get more information" ;
	skos:inScheme gx:slots .
dcat:packageFormat a owl:DatatypeProperty ;
	rdfs:label "packageFormat" ;
	rdfs:range xsd:string ;
	skos:definition "The package format of the distribution in which one or more data files are grouped together" ;
	skos:inScheme gx:slots .
odrl:hasPolicy a owl:DatatypeProperty ;
	rdfs:label "hasPolicy" ;
	rdfs:range xsd:string ;
	skos:definition "a list of policy expressed using ODRL" ;
	skos:inScheme gx:slots .
odrl:profile a owl:DatatypeProperty ;
	rdfs:label "odrlProfile" ;
	rdfs:range xsd:string ;
	skos:definition "The identifier(s) of an ODRL Profile that the Policy conforms to." ;
	skos:inScheme gx:slots .
schema:description a owl:DatatypeProperty ;
	rdfs:label "description" ;
	rdfs:range xsd:string ;
	skos:inScheme gx:slots .
schema:leiCode a owl:DatatypeProperty ;
	rdfs:label "leiCode" ;
	rdfs:range xsd:string ;
	skos:definition "Unique LEI number as defined by https://www.gleif.org." ;
	skos:inScheme gx:slots .
schema:name dcterms:title "name" ;
	a owl:DatatypeProperty ;
	rdfs:label "name" ;
	rdfs:range xsd:string ;
	skos:definition "A human readable name of the entity." ;
	skos:inScheme gx:slots .
schema:taxID a owl:DatatypeProperty ;
	rdfs:label "taxId" ;
	rdfs:range xsd:string ;
	skos:definition "The company tax ID." ;
	skos:inScheme gx:slots .
gx:AccessAttribute\/Append-Only a owl:Class ;
	rdfs:label "Append-Only" ;
	rdfs:subClassOf gx:AccessAttribute ;
	skos:definition "Allow for access in read-mode and to append data (ie write addtionnal data after the previous last byte)" .
gx:AccessAttribute\/Read-Only a owl:Class ;
	rdfs:label "Read-Only" ;
	rdfs:subClassOf gx:AccessAttribute ;
	skos:definition "Allow for access in read-mode only" .
gx:AccessAttribute\/Read-Write a owl:Class ;
	rdfs:label "Read-Write" ;
	rdfs:subClassOf gx:AccessAttribute ;
	skos:definition "Allow for access in both read-mode and write-mode (data deletion included)" .
gx:AccessAttribute a owl:Class ;
	rdfs:label "AccessAttribute" ;
	owl:unionOf _:c14n2782 ;
	skos:inScheme gx:storage-service-offering ;
	linkml:permissible_values gx:AccessAttribute\/Append-Only , gx:AccessAttribute\/Read-Only , gx:AccessAttribute\/Read-Write .
gx:AccessControlManagement a owl:Class ;
	rdfs:label "AccessControlManagement" ;
	rdfs:subClassOf gx:LegalDocument ;
	skos:definition "Legal document describing the management of access controls within the organization." ;
	skos:inScheme gx:legal-document .
gx:AccessTypes\/digital a owl:Class ;
	rdfs:label "digital" ;
	rdfs:subClassOf gx:AccessTypes ;
	skos:definition "Access via digital service, such as e-mail or web form." .
gx:AccessTypes\/physical a owl:Class ;
	rdfs:label "physical" ;
	rdfs:subClassOf gx:AccessTypes ;
	skos:definition "Access via physical medium, such as letter or physical appointment." .
gx:AccessTypes a owl:Class ;
	rdfs:label "AccessTypes" ;
	owl:unionOf _:c14n9291 ;
	skos:inScheme gx:service-offering ;
	linkml:permissible_values gx:AccessTypes\/digital , gx:AccessTypes\/physical .
gx:AccessUsagePolicy a owl:Class ;
	rdfs:label "AccessUsagePolicy" ;
	rdfs:subClassOf _:c14n3087 , _:c14n3727 , _:c14n6107 , _:c14n6495 , _:c14n7 , _:c14n861 ;
	skos:definition "An access or usage policy expressed using a DSL (e.g., Rego or ODRL) (access control, throttling, usage, retention, ...)." ;
	skos:inScheme gx:access-usage-policy .
gx:Address a owl:Class ;
	rdfs:label "Address" ;
	rdfs:subClassOf _:c14n1731 , _:c14n2423 , _:c14n2678 , _:c14n351 , _:c14n3557 , _:c14n3573 , _:c14n4077 , _:c14n4562 , _:c14n4689 , _:c14n4977 , _:c14n5192 , _:c14n5567 , _:c14n6310 , _:c14n6361 , _:c14n6408 , _:c14n6694 , _:c14n7007 , _:c14n756 , _:c14n8936 , _:c14n8956 ;
	skos:definition "Full address of the entity." ;
	skos:inScheme gx:address .
gx:Architectures\/AArch-32 a owl:Class ;
	rdfs:label "AArch-32" ;
	rdfs:subClassOf gx:Architectures ;
	skos:definition "32-bit version of ARM architecture." .
gx:Architectures\/AArch-64 a owl:Class ;
	rdfs:label "AArch-64" ;
	rdfs:subClassOf gx:Architectures ;
	skos:definition "64-bit version of ARM architecture." .
gx:Architectures\/Other a owl:Class ;
	rdfs:label "Other" ;
	rdfs:subClassOf gx:Architectures ;
	skos:definition "CPU architecture not specified above." .
gx:Architectures\/RISC-V a owl:Class ;
	rdfs:label "RISC-V" ;
	rdfs:subClassOf gx:Architectures ;
	skos:definition "Architecture based on open standard instruction set (ISA)." .
gx:Architectures\/x86-32 a owl:Class ;
	rdfs:label "x86-32" ;
	rdfs:subClassOf gx:Architectures ;
	skos:definition "32 bit version of x86 architecture." .
gx:Architectures\/x86-64 a owl:Class ;
	rdfs:label "x86-64" ;
	rdfs:subClassOf gx:Architectures ;
	skos:definition "64 bit version of x86 architecture." .
gx:Architectures a owl:Class ;
	rdfs:label "Architectures" ;
	owl:unionOf _:c14n6397 ;
	skos:inScheme gx:cpu ;
	linkml:permissible_values gx:Architectures\/AArch-32 , gx:Architectures\/AArch-64 , gx:Architectures\/Other , gx:Architectures\/RISC-V , gx:Architectures\/x86-32 , gx:Architectures\/x86-64 .
gx:AssetsManagement a owl:Class ;
	rdfs:label "AssetsManagement" ;
	rdfs:subClassOf gx:LegalDocument ;
	skos:definition "Legal document describing the management of assets related to security." ;
	skos:inScheme gx:legal-document .
gx:Availability dcterms:title "Availability" ;
	a owl:Class ;
	rdfs:label "Availability" ;
	rdfs:subClassOf gx:QoSMetric , _:c14n4896 , _:c14n5267 , _:c14n720 ;
	skos:definition "Contractual availability of connection defined in the SLA agreement. Availability is measured in the pseudo-unit \"percent\"." ;
	skos:inScheme gx:qos .
gx:AvailabilityZone dcterms:title "Availability Zone" ;
	a owl:Class ;
	rdfs:label "AvailabilityZone" ;
	rdfs:subClassOf gx:Resource , _:c14n199 , _:c14n3810 , _:c14n9283 ;
	skos:definition "An availability zone is an aggregation of resources - physical and abstract - in a non-redundant setup often associated with a single datacenter room" ;
	skos:inScheme gx:availability-zone .
gx:BackupPolicy a owl:Class ;
	rdfs:label "BackupPolicy" ;
	rdfs:subClassOf gx:DataProtectionPolicy , _:c14n1710 , _:c14n2843 , _:c14n4907 , _:c14n6203 ;
	skos:definition "Describe data protection features based on Backup for storage services" ;
	skos:inScheme gx:data-protection-policy .
gx:BandWidth dcterms:title "Bandwidth" ;
	a owl:Class ;
	rdfs:label "BandWidth" ;
	rdfs:subClassOf gx:QoSMetric , _:c14n1967 , _:c14n6799 , _:c14n8414 ;
	skos:definition "Contractual bandwidth defined in the service level agreement (SLA)." ;
	skos:inScheme gx:qos .
gx:BareMetalServiceOffering dcterms:title "Bare Metal Service Offering" ;
	a owl:Class ;
	rdfs:label "BareMetalServiceOffering" ;
	rdfs:subClassOf gx:ComputeServiceOffering , _:c14n2529 , _:c14n5024 , _:c14n76 , _:c14n9025 ;
	skos:definition "A digital service available for order and offering bare metal computational capabilities." ;
	skos:inScheme gx:service-offering .
gx:BaseContainerImage dcterms:title "Base Container Image" ;
	a owl:Class ;
	rdfs:label "BaseContainerImage" ;
	rdfs:subClassOf _:c14n2809 , _:c14n3715 , _:c14n6971 , _:c14n8419 , _:c14n9551 ;
	skos:definition "A set of tags for an image and a repository link" ;
	skos:inScheme gx:container-image .
gx:BlockAccessProtocol\/FCP a owl:Class ;
	rdfs:label "FCP" ;
	rdfs:subClassOf gx:BlockAccessProtocol ;
	skos:definition "Fiber Channel Protocol, cf https://en.wikipedia.org/wiki/Fibre_Channel" .
gx:BlockAccessProtocol\/FCoE a owl:Class ;
	rdfs:label "FCoE" ;
	rdfs:subClassOf gx:BlockAccessProtocol ;
	skos:definition "Fiber Channel over Ethernet protocol, cf https://en.wikipedia.org/wiki/Fibre_Channel_over_Ethernet" .
gx:BlockAccessProtocol\/Infiniband a owl:Class ;
	rdfs:label "Infiniband" ;
	rdfs:subClassOf gx:BlockAccessProtocol ;
	skos:definition "Infiniband protocol, cf https://en.wikipedia.org/wiki/InfiniBand" .
gx:BlockAccessProtocol\/NVME a owl:Class ;
	rdfs:label "NVME" ;
	rdfs:subClassOf gx:BlockAccessProtocol ;
	skos:definition "Directly attached local storage using NVME interface" .
gx:BlockAccessProtocol\/Other a owl:Class ;
	rdfs:label "Other" ;
	rdfs:subClassOf gx:BlockAccessProtocol ;
	skos:definition "Unspecified protocol" .
gx:BlockAccessProtocol\/SAS a owl:Class ;
	rdfs:label "SAS" ;
	rdfs:subClassOf gx:BlockAccessProtocol ;
	skos:definition "Directly attached local storage using SAS interface" .
gx:BlockAccessProtocol\/SATA a owl:Class ;
	rdfs:label "SATA" ;
	rdfs:subClassOf gx:BlockAccessProtocol ;
	skos:definition "Directly attached local storage using SATA interface" .
gx:BlockAccessProtocol a owl:Class ;
	rdfs:label "BlockAccessProtocol" ;
	owl:unionOf _:c14n2047 ;
	skos:inScheme gx:storage-configuration ;
	linkml:permissible_values gx:BlockAccessProtocol\/FCP , gx:BlockAccessProtocol\/FCoE , gx:BlockAccessProtocol\/Infiniband , gx:BlockAccessProtocol\/NVME , gx:BlockAccessProtocol\/Other , gx:BlockAccessProtocol\/SAS , gx:BlockAccessProtocol\/SATA .
gx:BlockStorageConfiguration dcterms:title "Block Storage Configuration" ;
	a owl:Class ;
	rdfs:label "BlockStorageConfiguration" ;
	rdfs:subClassOf gx:StorageConfiguration , _:c14n4871 , _:c14n7964 , _:c14n8719 , _:c14n9034 ;
	skos:definition "Represents the attributes that are configurable at service instantiation for storage service offerings." ;
	skos:inScheme gx:storage-configuration .
gx:BlockStorageServiceOffering dcterms:title "Block Storage Service Offering" ;
	a owl:Class ;
	rdfs:label "BlockStorageServiceOffering" ;
	rdfs:subClassOf gx:StorageServiceOffering , _:c14n4816 , _:c14n6672 , _:c14n8617 ;
	skos:definition "A digital service available for order and offering block storage capabilities." ;
	skos:inScheme gx:storage-service-offering .
gx:BlockStorageTechnology\/HDD a owl:Class ;
	rdfs:label "HDD" ;
	rdfs:subClassOf gx:BlockStorageTechnology ;
	skos:definition "Regular magnetic Hard Drive Disk" .
gx:BlockStorageTechnology\/Optane a owl:Class ;
	rdfs:label "Optane" ;
	rdfs:subClassOf gx:BlockStorageTechnology ;
	skos:definition "Intel Optane Drive" .
gx:BlockStorageTechnology\/SSD a owl:Class ;
	rdfs:label "SSD" ;
	rdfs:subClassOf gx:BlockStorageTechnology ;
	skos:definition "Solid State Drive" .
gx:BlockStorageTechnology a owl:Class ;
	rdfs:label "BlockStorageTechnology" ;
	owl:unionOf _:c14n7507 ;
	skos:inScheme gx:storage-configuration ;
	linkml:permissible_values gx:BlockStorageTechnology\/HDD , gx:BlockStorageTechnology\/Optane , gx:BlockStorageTechnology\/SSD .
gx:BusinessContinuityMeasures a owl:Class ;
	rdfs:label "BusinessContinuityMeasures" ;
	rdfs:subClassOf gx:LegalDocument ;
	skos:definition "Legal document describing the measures to ensure business continuity during security events." ;
	skos:inScheme gx:legal-document .
gx:CPU a owl:Class ;
	rdfs:label "CPU" ;
	rdfs:subClassOf gx:Device , _:c14n108 , _:c14n1174 , _:c14n1364 , _:c14n2004 , _:c14n2209 , _:c14n2268 , _:c14n2908 , _:c14n3135 , _:c14n4126 , _:c14n5149 , _:c14n5238 , _:c14n5617 , _:c14n6115 , _:c14n6403 , _:c14n6702 , _:c14n7152 , _:c14n7238 , _:c14n7437 , _:c14n7529 , _:c14n7627 , _:c14n9348 , _:c14n9360 , _:c14n9421 , _:c14n9506 , _:c14n9706 , _:c14n9757 ;
	skos:definition "Computational processing unit of virtual and physical machines." ;
	skos:inScheme gx:cpu .
gx:ChangeAndConfigurationManagement a owl:Class ;
	rdfs:label "ChangeAndConfigurationManagement" ;
	rdfs:subClassOf gx:LegalDocument ;
	skos:definition "Legal document describing the management of changes and configurations related to security." ;
	skos:inScheme gx:legal-document .
gx:CheckSum a owl:Class ;
	rdfs:label "CheckSum" ;
	rdfs:subClassOf _:c14n3122 , _:c14n4492 , _:c14n4570 , _:c14n5561 , _:c14n8963 , _:c14n9430 ;
	skos:definition "Detail on how to calculate or verify a checksum." ;
	skos:inScheme gx:cryptography .
gx:ChecksumAlgorithm\/blake2 a owl:Class ;
	rdfs:label "blake2" ;
	rdfs:subClassOf gx:ChecksumAlgorithm ;
	skos:definition "Improved version of the sha-3 algorithm Blake, optimized for 64-bit platforms, that generates digests of size between 1 and 64 bytes (Blake2b) or up to 32 bytes (Blake2s)." .
gx:ChecksumAlgorithm\/blake3 a owl:Class ;
	rdfs:label "blake3" ;
	rdfs:subClassOf gx:ChecksumAlgorithm ;
	skos:definition "Evolution of Bao and Blake2, although in contrast to these, doesn't offer different variants depending on the architectures, but just a single algorithm." .
gx:ChecksumAlgorithm\/md5 a owl:Class ;
	rdfs:label "md5" ;
	rdfs:subClassOf gx:ChecksumAlgorithm ;
	skos:definition "(Message Digest Method 5) Algorithm that generates a 128-bit digest, represented as 32-digit hexadecimal numbers, regardless the length of the input string." .
gx:ChecksumAlgorithm\/other a owl:Class ;
	rdfs:label "other" ;
	rdfs:subClassOf gx:ChecksumAlgorithm ;
	skos:definition "Algorithm to calculate checksum not further described." .
gx:ChecksumAlgorithm\/ripemd-160 a owl:Class ;
	rdfs:label "ripemd-160" ;
	rdfs:subClassOf gx:ChecksumAlgorithm ;
	skos:definition "RIPEMD-160 is a hash function from the RIPEMD (RIPE Message Digest) family that generates 160-bit hashes represented as 40-digit hexadecimal numbers." .
gx:ChecksumAlgorithm\/sha-1 a owl:Class ;
	rdfs:label "sha-1" ;
	rdfs:subClassOf gx:ChecksumAlgorithm ;
	skos:definition "(Secure Hash Algorithm 1) Algorithm that generates a 160-bit digest, typically represented as 40-digit hexadecimal numbers, regardless the length of the input string." .
gx:ChecksumAlgorithm\/sha-256 a owl:Class ;
	rdfs:label "sha-256" ;
	rdfs:subClassOf gx:ChecksumAlgorithm ;
	skos:definition "Cryptographic algorithm that produces a fixed-length, 256-bit (32-byte) hash value. The input text should be less than 264 bits length. The algorithm is irreversible by design." .
gx:ChecksumAlgorithm\/sha-384 a owl:Class ;
	rdfs:label "sha-384" ;
	rdfs:subClassOf gx:ChecksumAlgorithm ;
	skos:definition "This variant converts text of any length into a fixed-size string. Each output produces a hash of 384 bits." .
gx:ChecksumAlgorithm\/sha-3 a owl:Class ;
	rdfs:label "sha-3" ;
	rdfs:subClassOf gx:ChecksumAlgorithm ;
	skos:definition "Advanced version of the sha function, based on a sponge function approach, that generates an output bit stream of a desired length (56, 64, 96 or 128-digit hexadecimal numbers) depending of the sha-3 function version used." .
gx:ChecksumAlgorithm\/sha-512 a owl:Class ;
	rdfs:label "sha-512" ;
	rdfs:subClassOf gx:ChecksumAlgorithm ;
	skos:definition "This variant converts text of any length into a fixed-size string. Each output produces a hash of 512 bits (64 bytes)." .
gx:ChecksumAlgorithm a owl:Class ;
	rdfs:label "ChecksumAlgorithm" ;
