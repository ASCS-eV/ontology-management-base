gx:SignatureAlgorithm\/DSA a owl:Class ;
	rdfs:label "DSA" ;
	rdfs:subClassOf gx:SignatureAlgorithm ;
	skos:definition "DSA (Digital Signature Algorithm) is an asymmetric algorithm for signing information proposed by the NIST (National Institute of Standards and Technology)." .
gx:SignatureAlgorithm\/EC\%20Schnorr a owl:Class ;
	rdfs:label "EC Schnorr" ;
	rdfs:subClassOf gx:SignatureAlgorithm ;
	skos:definition "Elliptic Curve Based Schnorr signatura algorithm." .
gx:SignatureAlgorithm\/ECDSA a owl:Class ;
	rdfs:label "ECDSA" ;
	rdfs:subClassOf gx:SignatureAlgorithm ;
	skos:definition "ECDSA (Elliptic Curve Digital Signature Algorithm) is an improved variant of the DSA algorithm which uses keys derived from elliptic curve cryptography." .
gx:SignatureAlgorithm\/ECGDSA a owl:Class ;
	rdfs:label "ECGDSA" ;
	rdfs:subClassOf gx:SignatureAlgorithm ;
