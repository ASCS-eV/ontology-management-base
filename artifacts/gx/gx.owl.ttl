gx:SignatureAlgorithm\/ECKDSA a owl:Class ;
	rdfs:label "ECKDSA" ;
	rdfs:subClassOf gx:SignatureAlgorithm ;
	skos:definition "Elliptic Curve variant of the KCDSA algorithm." .
gx:SignatureAlgorithm\/KCDSA a owl:Class ;
	rdfs:label "KCDSA" ;
	rdfs:subClassOf gx:SignatureAlgorithm ;
	skos:definition "(Korean Certificate-based Digital Signature Algorithm), created by the Korea Internet & Security Agency (KISA), is similar to the DSA algorithm and can produce and output from 128 to 256 bits, in 32-bit increments." .
gx:SignatureAlgorithm\/RSA-Signature a owl:Class ;
	rdfs:label "RSA-Signature" ;
	rdfs:subClassOf gx:SignatureAlgorithm ;
	skos:definition "RSA is a cryptographic system based on public key that can be used both for signing and encryption purposes." .
gx:SignatureAlgorithm\/Schnorr a owl:Class ;
	rdfs:label "Schnorr" ;
	rdfs:subClassOf gx:SignatureAlgorithm ;
	skos:definition "Similar to ECDSA scheme was described by Claus Schnorr, is a well-known algorithm due to its simplicity and efficiency that generates short signatures." .
gx:SignatureAlgorithm\/other a owl:Class ;
	rdfs:label "other" ;
	rdfs:subClassOf gx:SignatureAlgorithm ;
	skos:definition "Algorithm for digital signatures not further described." .
