gx:MemoryRanks\/1R\%20RDIMM a owl:Class ;
	rdfs:label "1R RDIMM" ;
	rdfs:subClassOf gx:MemoryRanks ;
	skos:definition "(Registered DIMM) A single-rank (1R) memory module contains one set of DRAM chips that is accessed during writing/reading operations." .
gx:MemoryRanks\/2R\%20RDIMM a owl:Class ;
	rdfs:label "2R RDIMM" ;
	rdfs:subClassOf gx:MemoryRanks ;
	skos:definition "(Registered DIMM) A dual-rank (2R) memory module contains two sets of DRAM chips that are accessed during writing/reading operations." .
gx:MemoryRanks\/4R\%20LRDIMM a owl:Class ;
	rdfs:label "4R LRDIMM" ;
	rdfs:subClassOf gx:MemoryRanks ;
	skos:definition "(Load Reduced DIMM) A quad-rank (4R) memory module contains four sets of DRAM chips that are accessed during writing/reading operations." .
gx:MemoryRanks\/other a owl:Class ;
	rdfs:label "other" ;
	rdfs:subClassOf gx:MemoryRanks ;
	skos:definition "Memory rank no further described." .
gx:MemoryRanks a owl:Class ;
	rdfs:label "MemoryRanks" ;
	owl:unionOf _:c14n3553 ;
	skos:inScheme gx:memory ;
	linkml:permissible_values gx:MemoryRanks\/1R\%20RDIMM , gx:MemoryRanks\/2R\%20RDIMM , gx:MemoryRanks\/4R\%20LRDIMM , gx:MemoryRanks\/other .
