openlabel_v2:MotionUTurn a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "MotionUTurn" ;
    rdfs:range linkml:Boolean ;
    skos:definition "Subject performs a turn resulting in heading in the opposite direction." ;
