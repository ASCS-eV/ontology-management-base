openlabel_v2:SubjectVehicleSpeed a owl:ObjectProperty,
        linkml:SlotDefinition ;
    rdfs:label "SubjectVehicleSpeed" ;
    rdfs:range linkml:Boolean ;
    rdfs:seeAlso <https://www.bsigroup.com/en-GB/CAV/pas-1883> ;
