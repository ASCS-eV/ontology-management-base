                                            owl:onDatatype xsd:integer ;
                                            owl:withRestrictions ( [ xsd:minInclusive 1 ] ) ] ) ] openlabel_v2:QuantitativeValue ) ] ;
            owl:onProperty openlabel_v2:laneSpecificationLaneCountValue ],
