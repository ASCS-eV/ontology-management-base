            sh:maxCount 1 ;
            sh:message "JunctionRoundabout (OddScenery): Roundabout type. Refer to BSI PAS-1883 Section 5.2.4."@en ;
            sh:order 20 ;
            sh:path openlabel_v2:JunctionRoundabout ],
        [ sh:datatype xsd:boolean ;
